# Data files (keep structure, ignore actual data)
# Ignore all files in inputs/ except .gitkeep
inputs/*
!inputs/.gitkeep
# Also ignore lock files and temporary files
inputs/.~*
inputs/*~
inputs/.*.swp
inputs/.*.swo

# Config (keep example, ignore actual)
config/*.yaml
config/*.yml
!config/example.yaml

# Outputs
