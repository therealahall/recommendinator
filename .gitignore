# Data files (keep structure, ignore actual data)
# Ignore all files in inputs/ except .gitkeep
inputs/*
!inputs/.gitkeep
# Also ignore lock files and temporary files
inputs/.~*
inputs/*~
inputs/.*.swp
inputs/.*.swo

# Credential encryption keys (never commit)
.credential_key

# Config (keep example, ignore actual)
config/*.yaml
config/*.yml
!config/example.yaml

# Outputs
outputs/
# Note: recommendations/ is for output files, not src/recommendations/ code

# Private plugins (user-specific, not shared)
private/

# Docker Compose overrides (user-specific mounts)
docker-compose.override.yml
